# ===== iuria LexFutura - Environment Variables =====

# Database connection string (PostgreSQL)
# If not set, the system runs in MEMORY mode (data is not persisted across restarts)
DATABASE_URL=postgresql://user:password@localhost:5432/iuria

# JWT secret for authentication tokens
# Generate a random string: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=development

# MCP TecJustiça - Consulta Processual (92+ tribunais)
MCP_TECJUSTICA_URL=https://tecjusticamcp-lite-production.up.railway.app/mcp
MCP_TECJUSTICA_TOKEN=Bearer mcp_33327fa443b949069f8e9f7baa442784
